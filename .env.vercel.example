# Vercel Environment Variables Template
# Copy these to your Vercel project environment variables

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# Render API URL (if still needed for migration)
RENDER_API_URL=https://your-app.onrender.com

# Node Environment
NODE_ENV=production

# API Configuration
API_BASE_URL=https://your-vercel-app.vercel.app

# Security
JWT_SECRET=your-jwt-secret-key

# Payment Processing (if needed)
PAYSTACK_SECRET_KEY=your-paystack-secret-key
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key

# Email Service (if needed)
EMAIL_SERVICE_API_KEY=your-email-service-api-key

# Database Configuration (if using external DB)
DATABASE_URL=your-database-connection-string

# CORS Configuration
ALLOWED_ORIGINS=https://ojawa-ecommerce.web.app,https://ojawa-ecommerce-staging.web.app,https://ojawa.africa,https://www.ojawa.africa
