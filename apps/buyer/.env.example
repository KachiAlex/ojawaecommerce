# Ojawa Buyer App Environment Variables

# API Configuration
VITE_API_BASE_URL=https://ojawaecommerce.onrender.com

# Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=ojawa-ecommerce.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ojawa-ecommerce
VITE_FIREBASE_STORAGE_BUCKET=ojawa-ecommerce.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Payment Configuration
VITE_PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# App Configuration
VITE_APP_NAME=Ojawa
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CRASHLYTICS=true
VITE_ENABLE_EXTERNAL_LOGS=false
VITE_ENABLE_PUSH_NOTIFICATIONS=true

# Development
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# Testing
VITE_TEST_MODE=false
VITE_BYPASS_EMAIL_VERIFICATION=false
