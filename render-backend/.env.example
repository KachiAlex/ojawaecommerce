# Environment Configuration
NODE_ENV=production
PORT=8080

# Firebase Configuration
FIREBASE_PROJECT_ID=ojawa-ecommerce
FIREBASE_CLIENT_EMAIL=your-service-account@ojawa-ecommerce.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://ojawa-ecommerce.firebaseio.com
FIREBASE_API_KEY=your-web-api-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
ALLOWED_ORIGINS=https://ojawa.africa,https://www.ojawa.africa,https://ojawa-ecommerce.web.app,https://ojawa-ecommerce-staging.web.app

# Payment Gateways
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@ojawa.africa

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Database Configuration
FIRESTORE_CACHE_ENABLED=true
FIRESTORE_CACHE_SIZE_MB=100
